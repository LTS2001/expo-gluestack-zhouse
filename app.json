{
  "expo": {
    "name": "行间小筑",
    "slug": "expo-gluestack-zhouse",
    "orientation": "portrait",
    "scheme": "expogluestackzhouse",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.litaosheng.expogluestackzhouse"
    },
    "android": {
      "package": "com.litaosheng.expogluestackzhouse"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "445c4fbe-2176-477c-823a-f8e1cab17b85"
      }
    },
    "owner": "litaosheng"
  }
}
